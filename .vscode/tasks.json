{
    "version": "2.0.0",
    "tasks": [
        // Copy required Windows runtime DLLs (FFmpeg + ANGLE) to build output dirs.
        // Run this once after a clean or whenever the DLLs are missing.
        {
            "type": "shell",
            "label": "Windows: Copy Runtime DLLs",
            "command": "powershell",
            "args": [
                "-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/scripts/copy_win_dlls.ps1"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "detail": "Copy FFmpeg and ANGLE DLLs (including transitive deps) to Windows build output directories"
        },

        // Version Update Task
        {
            "type": "shell",
            "label": "Update Version",
            "command": "python",
            "args": ["scripts/update_version.py"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "Auto-increment version numbers"
        },

        // Generate IO Header from JSON definitions
        {
            "type": "shell",
            "label": "Generate IO Header",
            "command": "python",
            "args": ["scripts/generate_io_header.py"],
            "dependsOn": "Update Version",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "Generate src/system/io_defs_generated.h from src/user/io_definitions.json"
        },

        // Windows C/C++ single file EXE build
        {
            "type": "cppbuild",
            "label": "Windows: Single file build (Debug)",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fo${workspaceFolder}/build/windows/debug/",
                "/Fe${workspaceFolder}/build/windows/debug/${fileBasenameNoExtension}.exe",
                "/Fd${workspaceFolder}/build/windows/debug/${fileBasenameNoExtension}.pdb",
                "${file}",
                "/I${workspaceFolder}/src/include_ogl_win",
                "/I${workspaceFolder}/src/3rdparty",
                "/link",
                "/LIBPATH:${workspaceFolder}/src/lib_ogl_win",
                "/LIBPATH:C:/Program Files (x86)/Windows Kits/10/Lib/10.0.26100.0/um/x64",
                "libegl.dll.lib",
                "libglesv2.dll.lib",
                "kernel32.lib",
                "user32.lib",
                "gdi32.lib",
                "winspool.lib",
                "comdlg32.lib",
                "advapi32.lib",
                "shell32.lib",
                "ole32.lib",
                "oleaut32.lib",
                "uuid.lib",
                "odbc32.lib",
                "odbccp32.lib",
                "/machine:x64"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Windows: Single file build"
        },

        // Raspberry Pi: Single File Build
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: Single File Build (Debug)",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "-o",
                "${workspaceFolder}/build/raspi/debug/${fileBasenameNoExtension}",
                "${file}",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-L${workspaceFolder}/src/lib_ogl_raspi"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: Single File Build"
        },

        // Windows Full Build for Pinball
        {
            "type": "cppbuild",
            "label": "Windows: Full Pinball Build (Debug)",
            "command": "cl.exe",
            "dependsOn": ["Generate IO Header", "Windows: Copy Runtime DLLs"],
            "dependsOrder": "parallel",
            "args": [
                "/Zi",
                "/DEXE_MODE_WINDOWS",
                "/EHsc",
                "/nologo",
                "/Fo${workspaceFolder}/build/windows/debug/",
                "/Fe${workspaceFolder}/build/windows/debug/Pinball.exe",
                "/Fd${workspaceFolder}/build/windows/debug/Pinball.pdb",
                "${workspaceFolder}/src/3rdparty/stb_image.cpp",
                "${workspaceFolder}/src/3rdparty/cgltf.cpp",
                "${workspaceFolder}/src/system/PBOGLES.cpp",
                "${workspaceFolder}/src/system/PB3D.cpp",
                "${workspaceFolder}/src/system/PBGfx.cpp",
                "${workspaceFolder}/src/system/PBWinRender.cpp",
                "${workspaceFolder}/src/system/PBDebounce.cpp",
                "${workspaceFolder}/src/user/PBDevice.cpp",
                "${workspaceFolder}/src/system/Pinball_IO.cpp",
                "${workspaceFolder}/src/system/Pinball_Table.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeInit.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeStart.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeMain.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeReset.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeGameEnd.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModePlayerEnd.cpp",
                "${workspaceFolder}/src/system/PBSound.cpp",
                "${workspaceFolder}/src/system/PBVideo.cpp",
                "${workspaceFolder}/src/system/PBVideoPlayer.cpp",
                "${workspaceFolder}/src/system/PinballMenus.cpp",
                "${workspaceFolder}/src/user/PBSequences.cpp",
                "${workspaceFolder}/src/system/Pinball_Engine.cpp",
                "${workspaceFolder}/src/system/Pinball.cpp",
                "/I${workspaceFolder}/src",
                "/I${workspaceFolder}/src/system",
                "/I${workspaceFolder}/src/user",
                "/I${workspaceFolder}/src/include_ogl_win",
                "/I${workspaceFolder}/src/3rdparty",
                "/link",
                "/LIBPATH:${workspaceFolder}/src/lib_ogl_win",
                "/LIBPATH:C:/Program Files (x86)/Windows Kits/10/Lib/10.0.26100.0/um/x64",
                "libegl.dll.lib",
                "libglesv2.dll.lib",
                "avcodec.lib",
                "avformat.lib",
                "avutil.lib",
                "swscale.lib",
                "swresample.lib",
                "kernel32.lib",
                "user32.lib",
                "gdi32.lib",
                "winspool.lib",
                "comdlg32.lib",
                "advapi32.lib",
                "shell32.lib",
                "ole32.lib",
                "oleaut32.lib",
                "uuid.lib",
                "odbc32.lib",
                "odbccp32.lib",
                "/machine:x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Windows: Full Pinball Build (Debug)"
        },

        // Raspberry Pi: Full Build
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: Full Pinball Build (Debug)",
            "command": "/usr/bin/g++",
            "dependsOn": "Generate IO Header",
            "args": [
                "-g",
                "-DEXE_MODE_RASPI",
                "-o",
                "${workspaceFolder}/build/raspi/debug/Pinball",
                "${workspaceFolder}/src/3rdparty/stb_image.cpp",
                "${workspaceFolder}/src/3rdparty/cgltf.cpp",
                "${workspaceFolder}/src/system/PBOGLES.cpp",
                "${workspaceFolder}/src/system/PB3D.cpp",
                "${workspaceFolder}/src/system/PBGfx.cpp",
                "${workspaceFolder}/src/system/PBLinuxRender.cpp",
                "${workspaceFolder}/src/system/PBDebounce.cpp",
                "${workspaceFolder}/src/user/PBDevice.cpp",
                "${workspaceFolder}/src/system/Pinball_IO.cpp",
                "${workspaceFolder}/src/system/Pinball_Table.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeInit.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeStart.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeMain.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeReset.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeGameEnd.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModePlayerEnd.cpp",
                "${workspaceFolder}/src/system/PBSound.cpp",
                "${workspaceFolder}/src/system/PBVideo.cpp",
                "${workspaceFolder}/src/system/PBVideoPlayer.cpp",
                "${workspaceFolder}/src/system/PinballMenus.cpp",
                "${workspaceFolder}/src/user/PBSequences.cpp",
                "${workspaceFolder}/src/system/Pinball_Engine.cpp",
                "${workspaceFolder}/src/system/Pinball.cpp",
                "-I${workspaceFolder}/src",
                "-I${workspaceFolder}/src/system",
                "-I${workspaceFolder}/src/user",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-I/usr/include/EGL",
                "-I/usr/include/GLES3",
                "-I/usr/include/KHR",
                "-I/usr/include/X11",
                "-I/usr/include/X11/extensions",
                "-lEGL",
                "-lGLESv2",
                "-lpthread",
                "-lm",
                "-lX11",
                "-lXrandr",
                "-lwiringPi",
                "-lSDL2",
                "-lSDL2_mixer",
                "-lavcodec",
                "-lavformat",
                "-lavutil",
                "-lswscale",
                "-lswresample"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: Full Pinball Build (Debug)"
        },

        // DebianOS: Full Build
        {
            "type": "cppbuild",
            "label": "DebianOS: Full Pinball Build (Debug)",
            "command": "/usr/bin/g++",
            "dependsOn": "Generate IO Header",
            "args": [
                "-g",
                "-DEXE_MODE_DEBIAN",
                "-o",
                "${workspaceFolder}/build/debian/debug/Pinball_DebianOS",
                "${workspaceFolder}/src/3rdparty/stb_image.cpp",
                "${workspaceFolder}/src/3rdparty/cgltf.cpp",
                "${workspaceFolder}/src/system/PBOGLES.cpp",
                "${workspaceFolder}/src/system/PB3D.cpp",
                "${workspaceFolder}/src/system/PBGfx.cpp",
                "${workspaceFolder}/src/system/PBLinuxRender.cpp",
                "${workspaceFolder}/src/system/PBDebounce.cpp",
                "${workspaceFolder}/src/user/PBDevice.cpp",
                "${workspaceFolder}/src/system/Pinball_IO.cpp",
                "${workspaceFolder}/src/system/Pinball_Table.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeInit.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeStart.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeMain.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeReset.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeGameEnd.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModePlayerEnd.cpp",
                "${workspaceFolder}/src/system/PBSound.cpp",
                "${workspaceFolder}/src/system/PBVideo.cpp",
                "${workspaceFolder}/src/system/PBVideoPlayer.cpp",
                "${workspaceFolder}/src/system/PinballMenus.cpp",
                "${workspaceFolder}/src/user/PBSequences.cpp",
                "${workspaceFolder}/src/system/Pinball_Engine.cpp",
                "${workspaceFolder}/src/system/Pinball.cpp",
                "-I${workspaceFolder}/src",
                "-I${workspaceFolder}/src/system",
                "-I${workspaceFolder}/src/user",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-I/usr/include/EGL",
                "-I/usr/include/GLES3",
                "-I/usr/include/KHR",
                "-I/usr/include/X11",
                "-I/usr/include/X11/extensions",
                "-lEGL",
                "-lGLESv2",
                "-lpthread",
                "-lm",
                "-lX11",
                "-lXrandr",
                "-lSDL2",
                "-lSDL2_mixer",
                "-lavcodec",
                "-lavformat",
                "-lavutil",
                "-lswscale",
                "-lswresample"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "DebianOS: Full Pinball Build (Debug)"
        },

        // FontGen Windows Build
        {
            "type": "cppbuild",
            "label": "Windows: FontGen Build (Debug)",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fo${workspaceFolder}/build/windows/debug/",
                "/Fe${workspaceFolder}/build/windows/debug/FontGen.exe",
                "/Fd${workspaceFolder}/build/windows/debug/FontGen.pdb",
                "${workspaceFolder}/src/3rdparty/stb_truetype.cpp",
                "${workspaceFolder}/src/3rdparty/stb_image_write.cpp",
                "${workspaceFolder}/src/PButils/FontGen.cpp",
                "/I${workspaceFolder}/src/include_ogl_win",
                "/I${workspaceFolder}/src/3rdparty",
                "/link",
                "/LIBPATH:C:/Program Files (x86)/Windows Kits/10/Lib/10.0.26100.0/um/x64",
                "kernel32.lib",
                "user32.lib",
                "gdi32.lib",
                "winspool.lib",
                "comdlg32.lib",
                "advapi32.lib",
                "shell32.lib",
                "ole32.lib",
                "oleaut32.lib",
                "uuid.lib",
                "odbc32.lib",
                "odbccp32.lib",
                "/machine:x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Windows: FontGen Build (Debug)"
        },

        // Raspberry Pi: FontGen Build
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: FontGen Build (Debug)",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "-o",
                "${workspaceFolder}/build/raspi/debug/FontGen",
                "${workspaceFolder}/src/3rdparty/stb_truetype.cpp",
                "${workspaceFolder}/src/3rdparty/stb_image_write.cpp",
                "${workspaceFolder}/src/PButils/FontGen.cpp",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-L${workspaceFolder}/src/lib_ogl_raspi",
                "-lEGL",
                "-lGLESv2",
                "-lpthread"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: FontGen Build (Debug)"
        },

        // Raspberry Pi: pblistdevices Build
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: pblistdevices Build (Debug)",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "-o",
                "${workspaceFolder}/build/raspi/debug/pblistdevices",
                "${workspaceFolder}/src/PButils/pblistdevices.cpp",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-L${workspaceFolder}/src/lib_ogl_raspi",
                "-lwiringPi",
                "-lpthread"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: pblistdevices Build (Debug)"
        },

        // Raspberry Pi: pbsetamp Build
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: pbsetamp Build (Debug)",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "-o",
                "${workspaceFolder}/build/raspi/debug/pbsetamp",
                "${workspaceFolder}/src/PButils/pbsetamp.cpp",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-L${workspaceFolder}/src/lib_ogl_raspi",
                "-lwiringPi",
                "-lpthread"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: pbsetamp Build (Debug)"
        },

        // Raspberry Pi: pblaunch Build (GTK4 GUI launcher)
        {
            "type": "shell",
            "label": "Raspberry Pi: pblaunch Build (Debug)",
            "command": "g++ -std=c++17 -g -o ${workspaceFolder}/build/raspi/debug/pblaunch ${workspaceFolder}/src/PButils/pblaunch.cpp $(pkg-config --cflags --libs gtk4)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: pblaunch GTK4 GUI launcher build"
        },

        // Windows: Build All PBUtils
        {
            "label": "Windows: Build All PBUtils (Debug)",
            "dependsOn": [
                "Windows: FontGen Build (Debug)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Build all PBUtils executables for Windows (FontGen only - pblistdevices and pbsetamp require wiringPi)"
        },

        // Raspberry Pi: Build All PBUtils
        {
            "label": "Raspberry Pi: Build All PBUtils (Debug)",
            "dependsOn": [
                "Raspberry Pi: FontGen Build (Debug)",
                "Raspberry Pi: pblistdevices Build (Debug)",
                "Raspberry Pi: pbsetamp Build (Debug)",
                "Raspberry Pi: pblaunch Build (Debug)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Build all PBUtils executables for Raspberry Pi"
        },

        // Windows Release Build (Optimized)
        {
            "type": "cppbuild",
            "label": "Windows: Full Pinball Build (Release)",
            "command": "cl.exe",
            "dependsOn": ["Generate IO Header", "Windows: Copy Runtime DLLs"],
            "dependsOrder": "parallel",
            "args": [
                "/O2",                    // Maximum optimization
                "/Oi",                    // Enable intrinsic functions
                "/Ot",                    // Favor fast code
                "/Oy",                    // Omit frame pointers
                "/GL",                    // Whole program optimization
                "/DNDEBUG",               // Define NDEBUG for release
                "/DEXE_MODE_WINDOWS",
                "/EHsc",
                "/nologo",
                "/Fo${workspaceFolder}/build/windows/release/",
                "/Fe${workspaceFolder}/build/windows/release/Pinball.exe",
                "${workspaceFolder}/src/3rdparty/stb_image.cpp",
                "${workspaceFolder}/src/3rdparty/cgltf.cpp",
                "${workspaceFolder}/src/system/PBOGLES.cpp",
                "${workspaceFolder}/src/system/PB3D.cpp",
                "${workspaceFolder}/src/system/PBGfx.cpp",
                "${workspaceFolder}/src/system/PBWinRender.cpp",
                "${workspaceFolder}/src/system/PBDebounce.cpp",
                "${workspaceFolder}/src/user/PBDevice.cpp",
                "${workspaceFolder}/src/system/Pinball_IO.cpp",
                "${workspaceFolder}/src/system/Pinball_Table.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeInit.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeStart.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeMain.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeReset.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeGameEnd.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModePlayerEnd.cpp",
                "${workspaceFolder}/src/system/PBSound.cpp",
                "${workspaceFolder}/src/system/PBVideo.cpp",
                "${workspaceFolder}/src/system/PBVideoPlayer.cpp",
                "${workspaceFolder}/src/system/PinballMenus.cpp",
                "${workspaceFolder}/src/user/PBSequences.cpp",
                "${workspaceFolder}/src/system/Pinball_Engine.cpp",
                "${workspaceFolder}/src/system/Pinball.cpp",
                "/I${workspaceFolder}/src",
                "/I${workspaceFolder}/src/system",
                "/I${workspaceFolder}/src/user",
                "/I${workspaceFolder}/src/include_ogl_win",
                "/I${workspaceFolder}/src/3rdparty",
                "/link",
                "/LTCG",                  // Link-time code generation
                "/OPT:REF",               // Remove unreferenced functions
                "/OPT:ICF",               // Enable COMDAT folding
                "/LIBPATH:${workspaceFolder}/src/lib_ogl_win",
                "/LIBPATH:C:/Program Files (x86)/Windows Kits/10/Lib/10.0.26100.0/um/x64",
                "libegl.dll.lib",
                "libglesv2.dll.lib",
                "avcodec.lib",
                "avformat.lib",
                "avutil.lib",
                "swscale.lib",
                "swresample.lib",
                "kernel32.lib",
                "user32.lib",
                "gdi32.lib",
                "winspool.lib",
                "comdlg32.lib",
                "advapi32.lib",
                "shell32.lib",
                "ole32.lib",
                "oleaut32.lib",
                "uuid.lib",
                "odbc32.lib",
                "odbccp32.lib",
                "/machine:x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Windows: Optimized Release Build"
        },

        // Raspberry Pi Release Build (Optimized)
        {
            "type": "cppbuild",
            "label": "Raspberry Pi: Full Pinball Build (Release)",
            "command": "/usr/bin/g++",
            "dependsOn": "Generate IO Header",
            "args": [
                "-O3",                    // Maximum optimization
                "-march=native",          // Optimize for target CPU
                "-mtune=native",          // Tune for target CPU
                "-flto",                  // Link-time optimization
                "-ffast-math",            // Fast math optimizations
                "-funroll-loops",         // Unroll loops
                "-DNDEBUG",               // Define NDEBUG for release
                "-DEXE_MODE_RASPI",
                "-o",
                "${workspaceFolder}/build/raspi/release/Pinball",
                "${workspaceFolder}/src/3rdparty/stb_image.cpp",
                "${workspaceFolder}/src/3rdparty/cgltf.cpp",
                "${workspaceFolder}/src/system/PBOGLES.cpp",
                "${workspaceFolder}/src/system/PB3D.cpp",
                "${workspaceFolder}/src/system/PBGfx.cpp",
                "${workspaceFolder}/src/system/PBLinuxRender.cpp",
                "${workspaceFolder}/src/system/PBDebounce.cpp",
                "${workspaceFolder}/src/user/PBDevice.cpp",
                "${workspaceFolder}/src/system/Pinball_IO.cpp",
                "${workspaceFolder}/src/system/Pinball_Table.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeInit.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeStart.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeMain.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeReset.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModeGameEnd.cpp",
                "${workspaceFolder}/src/user/tablemodes/Pinball_Table_ModePlayerEnd.cpp",
                "${workspaceFolder}/src/system/PBSound.cpp",
                "${workspaceFolder}/src/system/PBVideo.cpp",
                "${workspaceFolder}/src/system/PBVideoPlayer.cpp",
                "${workspaceFolder}/src/system/PinballMenus.cpp",
                "${workspaceFolder}/src/user/PBSequences.cpp",
                "${workspaceFolder}/src/system/Pinball_Engine.cpp",
                "${workspaceFolder}/src/system/Pinball.cpp",
                "-I${workspaceFolder}/src",
                "-I${workspaceFolder}/src/system",
                "-I${workspaceFolder}/src/user",
                "-I${workspaceFolder}/src/include_ogl_raspi",
                "-I${workspaceFolder}/src/3rdparty",
                "-I/usr/include/EGL",
                "-I/usr/include/GLES3",
                "-I/usr/include/KHR",
                "-I/usr/include/X11",
                "-I/usr/include/X11/extensions",
                "-lEGL",
                "-lGLESv2",
                "-lpthread",
                "-lm",
                "-lX11",
                "-lXrandr",
                "-lwiringPi",
                "-lSDL2",
                "-lSDL2_mixer",
                "-lavcodec",
                "-lavformat",
                "-lavutil",
                "-lswscale",
                "-lswresample",
                "-s"                      // Strip symbols for smaller binary
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Raspberry Pi: Optimized Release Build"
        }
    ]
}
